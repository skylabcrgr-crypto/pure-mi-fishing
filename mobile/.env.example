# Pure MI Fishing — Mobile Environment Variables (Phase 7)
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in. All vars are OPTIONAL — the app runs fully
# offline without them. Only EXPO_PUBLIC_* vars are exposed to the client.
#
# NEVER put a Supabase service-role key in this file or the mobile app.
# ----------------------------------------------------------------------------

# Supabase project URL (Supabase Studio → Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — safe to ship in client (RLS enforces access)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# App environment label shown in diagnostics: development | preview | production
EXPO_PUBLIC_APP_ENV=development

# Optional: base URL for statically-hosted offline data packs
# e.g. https://packs.puremifishing.pages.dev
EXPO_PUBLIC_DATA_PACK_BASE_URL=
